# ==============================================================================
# Telegram Content Distribution & Local Media Ingestion Platform .env.example
# ==============================================================================

# Node Environment ('development' or 'production')
NODE_ENV=production

# App Server Port Configuration (Default: 3000)
PORT=3000

# Base Canonical Server URL for Link-Tracking Clicks and Redirection Routing
APP_URL=https://your-domain.com

# Gemini API Private Secret Key (Used server-side only for content caption crafting)
GEMINI_API_KEY=

# Cloudflare R2 Credentials (Optional: Used when UPLOAD_MODE=R2_STORAGE)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Supabase DB & Storage Connection (Optional: Used when UPLOAD_MODE=SUPABASE_STORAGE)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_CONNECTION_STRING=

# Security Token Keys
API_GATEWAY_SECRET_KEY=vpstg_agent_secret_2026
ADMIN_PANEL_PASSWORD=AdminSecurePassword2026
